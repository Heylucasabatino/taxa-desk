{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Taxa Desk",
  "version": "0.1.7",
  "identifier": "it.local.fondi-e-tasse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Taxa Desk",
        "width": 1360,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCQzJENTlFMkM5OURBMjUKUldRbDJwa3NudFhDYXdOTHUrNkhGMCtvNi9adyswQnl1NVFlN3ltRlhMdHFDTHlrNTdQb25LcjEK",
      "endpoints": [
        "https://github.com/Heylucasabatino/taxa-desk/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
